generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model WorkforceGraph {
  id            String                  @id @default(cuid())
  name          String
  graph         Json
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  chatMessages  WorkforceChatMessage[]
  chatSessions  WorkforceChatSession[]
}

model WorkforceChatSession {
  id        String   @id @default(cuid())
  graphId   String
  agentId   String
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  graph    WorkforceGraph         @relation(fields: [graphId], references: [id], onDelete: Cascade)
  messages WorkforceChatMessage[]

  @@index([graphId, agentId, updatedAt])
}

model WorkforceChatMessage {
  id        String   @id @default(cuid())
  graphId   String
  agentId   String
  sessionId String?
  role      String
  content   String
  createdAt DateTime @default(now())

  graph   WorkforceGraph          @relation(fields: [graphId], references: [id], onDelete: Cascade)
  session WorkforceChatSession?   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([graphId, agentId, createdAt])
  @@index([sessionId, createdAt])
}
